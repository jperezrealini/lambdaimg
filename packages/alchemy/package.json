{
  "name": "@lambdaimg/alchemy",
  "version": "0.4.0",
  "description": "AWS Alchemy stack and Lambda runtime for LambdaImg.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jperezrealini/lambdaimg.git",
    "directory": "packages/alchemy"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "default": "./dist/stack.js",
      "types": "./dist/stack.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "oxlint && oxfmt --check && tsc --noEmit -p tsconfig.json",
    "fix": "oxlint --fix && oxfmt",
    "test": "bun test",
    "test:e2e": "RUN_AWS_E2E=1 bun test test/e2e.test.ts",
    "test:e2e:destroy": "alchemy destroy test/fixtures/e2e-stack.ts --stage \"${ALCHEMY_STAGE:-test}\" --yes"
  },
  "dependencies": {
    "@lambdaimg/core": "workspace:*",
    "alchemy": "2.0.0-beta.58",
    "effect": "4.0.0-beta.90",
    "heic-convert": "^2.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@distilled.cloud/aws": "0.26.1",
    "@effect/platform-node": "4.0.0-beta.90",
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}
