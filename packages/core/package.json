{
  "name": "@lambdaimg/core",
  "version": "0.1.0",
  "description": "Core URL and srcset primitives for LambdaImg.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jperezrealini/lambdaimg.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
