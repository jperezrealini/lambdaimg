{
  "name": "lambdaimg-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "catalog": {
      "@types/bun": "^1.3.4",
      "@types/node": "^24.0.0"
    },
    "packages": [
      "packages/*",
      "examples/*"
    ]
  },
  "type": "module",
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "changeset": "changeset",
    "check": "bun run --filter './packages/*' check",
    "fix": "bun run --filter './packages/*' fix",
    "release": "bun run --filter './packages/*' build && changeset publish",
    "test": "bun run --filter './packages/*' test",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "7.0.1-rc"
  },
  "packageManager": "bun@1.3.14"
}
